# Supabase (public — safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only, used from Route Handlers / Server Actions, Stage 9+)
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Map (optional — falls back to a keyless CARTO dark basemap if unset,
# recommended for production: https://www.maptiler.com/)
NEXT_PUBLIC_MAPTILER_API_KEY=

# Stripe (Stage 15 — architecture only, no live payment processing yet).
# Leave unset to keep the app in demo mode: the pricing page renders fully,
# but /api/billing/checkout responds with a friendly "not configured"
# message instead of creating a real Checkout Session.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
